# 공공데이터포털에서 발급받은 서비스키를 넣으세요.
# odcloud(한국부동산원 청약홈) 계열 API는 DECODING_KEY(원본 형태)를 사용합니다.
DECODING_KEY=

# LH(한국토지주택공사) 계열 API는 ENCODING_KEY(URL 인코딩된 형태)를 사용합니다.
ENCODING_KEY=

# MCP 서버 실행 방식.
# - 로컬 개발(Claude Desktop 등 stdio 클라이언트): stdio (기본값)
# - Docker/EC2처럼 네트워크로 접속해야 하는 배포 환경: streamable-http
MCP_TRANSPORT=stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000
